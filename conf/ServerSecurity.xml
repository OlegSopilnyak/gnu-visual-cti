<SecurityDatabase>
	<group name="Administrators">
User group, which have
permissions to control a server
<filter default="allowed">
			<!--Filter for Administrators-->
			<rule path="{Server}" type="allowed" error="true" event="stop|start|state" command="stop|start|get|set" response="true">
				<!--Permissible definition of a rule of a filter-->
			</rule>
		</filter>
	</group>
	<group name="Guests">
User group, the visitors,
have not any permissions, by default
<filter default="allowed">
			<!--Filter for Guests-->
			<rule path="{Server}" type="denied" error="true" event="stop|start|state" command="stop|start|get|set" response="true">
				<!--Not permissible definition of a rule of a filter-->
			</rule>
			<rule path="/Service" type="denied" error="true" event="stop|start|state" command="stop|start|get|set" response="true">
				<!--Not permissible definition of a rule of a filter-->
			</rule>
		</filter>
	</group>
	<group name="Servers">
User group, server, have permissions to do everything,
except for access to the stoppage of a server
<filter default="allowed">
			<!--Filter for Servers-->
			<rule path="{Server}" type="allowed" error="true" event="stop|start|state" command="get|set" response="true">
				<!--Permissible definition of a rule of a filter-->
			</rule>
		</filter>
	</group>
	<user login="adm" password="adm" group="Administrators" name="Oleg Sopilnyak">
olegsopilnyak@yahoo.com
    <filter default="allowed">
			<!--Filter for Servers-->
			<rule path="{Server}" type="allowed" error="true" event="stop|start|state" command="get|set" response="true">
				<!--Permissible definition of a rule of a filter-->
			</rule>
		</filter>
	</user>
	<user login="g" password="g" group="Guests" name="Jon Dow">
JonDow@yahoo.com
    <filter default="denied">
			<!--Filter for Servers-->
			<rule path="{Server}" type="denied" error="true" event="stop|start|state" command="get|set" response="true">
				<!--Permissible definition of a rule of a filter-->
			</rule>
		</filter>
	</user>
	<unit path="{Server}"/>
	<unit path="/Service"/>
	<unit path="/Service/Messenger"/>
	<unit path="/Service/Messenger/EMAIL"/>
	<unit path="/Service/Log"/>
	<unit path="/Service/Security"/>
</SecurityDatabase>
