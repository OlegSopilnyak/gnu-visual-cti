              </runtime>
              <link default="Library.chain.0:IF.2" />
            </briquette>
            <briquette class="org.visualcti.briquette.control.Branching">
              <!--base properties of the briquette-->
              <base>
                <property name="ID" type="string">Library.chain.0:IF.2</property>
                <property name="master" type="boolean">false</property>
                <property name="about" type="string">Is valid input</property>
                <property name="coordinates" type="point">
                  <coord X="380.0" Y="10.0" />
                </property>
              </base>
              <!--runtime properties of the briquette-->
              <runtime>
                <logic>
                  <logic_part>
                    <calculate type="logical">
                      <expression first="db:db.DataAccess(string) const false" operation="=" second="local:Yes(string) const true" />
                    </calculate>
                  </logic_part>
                </logic>
              </runtime>
              <link default="Library.chain.0:Play.1" alternate="Library.chain.0:IF.0" />
            </briquette>
            <briquette class="org.visualcti.briquette.telephony.PlayAction">
              <!--base properties of the briquette-->
              <base>
                <property name="ID" type="string">Library.chain.0:Play.1</property>
