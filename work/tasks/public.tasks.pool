                  <logic_part>
                    <calculate type="logical">
                      <expression first="system:cti.Input(string) const false" operation="=" second="system:cti.Input(string) const false" />
                    </calculate>
                    <next condition="AND" />
                  </logic_part>
                  <logic_part>
                    <calculate type="logical">
                      <expression first="local:Assemly Code(string) const false" operation="=" second="local:Assemly Code(string) const false" />
                    </calculate>
                  </logic_part>
                </logic>
