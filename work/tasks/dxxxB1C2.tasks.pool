        <briquette class="org.visualcti.briquette.telephony.Input">
          <!--base properties of the briquette-->
          <base>
            <property name="ID" type="string">Main-chain:Operation.2</property>
            <property name="master" type="boolean">false</property>
            <property name="about" type="string">To accept an extension</property>
            <property name="coordinates" type="point">
              <coord X="460.0" Y="100.0" />
            </property>
          </base>
          <!--runtime properties of the briquette-->
          <runtime>
            <property name="beepBefore" type="boolean">false</property>
            <property name="quantity" type="symbol">local:10(number) const true</property>
            <property name="timeout" type="symbol">local:5(number) const true</property>
            <set type="DTMF" value="#" />
          </runtime>
          <link default="Main-chain:IF.7" />
        </briquette>
        <briquette class="org.visualcti.briquette.data.Math">
          <!--base properties of the briquette-->
          <base>
