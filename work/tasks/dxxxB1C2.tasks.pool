          <!--base properties of the briquette-->
          <base>
            <property name="ID" type="string">Main-chain:IF.7</property>
            <property name="master" type="boolean">false</property>
            <property name="about" type="string">Timeout detected?</property>
            <property name="coordinates" type="point">
              <coord X="450.0" Y="190.0" />
            </property>
          </base>
          <!--runtime properties of the briquette-->
          <runtime>
            <logic>
              <logic_part>
